RewriteEngine On

# =====================================================
# 1. ПРИНУДИТЕЛЬНЫЙ HTTPS
# =====================================================

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# =====================================================
# 2. КРАСИВЫЕ URL БЕЗ .HTML
# =====================================================

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|txt|xml|json|webmanifest|woff|woff2|ttf|eot)$
RewriteRule ^([^/]+)$ /$1.html [L]

# =====================================================
# 3. 🔥 ПОИСК СТАТЬИ ПО НАЗВАНИЮ (с пробелами)
# =====================================================

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)$ /article-redirect.php?title=$1 [L]

# =====================================================
# 4. КОРЕНЬ → index.html
# =====================================================

RewriteRule ^$ /index.html [L]

# =====================================================
# 5. 404 ОШИБКА
# =====================================================

ErrorDocument 404 /404.html

# =====================================================
# 6. БЕЗОПАСНОСТЬ — XSS, CSRF, CLICKJACKING
# =====================================================

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://*.firebaseio.com https://*.firebaseapp.com https://*.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.imgur.com https://*.imgbb.com https://i.ibb.co https://*.googleapis.com; connect-src 'self' https://*.firebaseio.com https://*.firebaseapp.com https://api.imgbb.com https://*.googleapis.com; font-src 'self'; frame-src 'self' https://*.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
</IfModule>

# =====================================================
# 7. ЗАЩИТА ОТ SQL ИНЪЕКЦИЙ И XSS ЧЕРЕЗ URL
# =====================================================

<IfModule mod_rewrite.c>
    RewriteCond %{QUERY_STRING} (<|>|'|\"|%3C|%3E|%27|%22) [NC,OR]
    RewriteCond %{QUERY_STRING} (javascript:|alert\(|onerror=|onload=|onclick=|onmouseover=) [NC,OR]
    RewriteCond %{QUERY_STRING} (eval\(|document\.|window\.|location\.|cookie|localStorage|sessionStorage) [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./|\.\.\\|/etc/passwd|/proc/self/environ) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# =====================================================
# 8. ЗАПРЕТ ДОСТУПА К СКРЫТЫМ И ОПАСНЫМ ФАЙЛАМ
# =====================================================

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "(config|database|\.log|\.ini|\.sql|\.sh|\.env|\.json|serviceAccountKey)">
    Order allow,deny
    Deny from all
</FilesMatch>

# =====================================================
# 9. ЗАПРЕТ ЛИСТИНГА ДИРЕКТОРИЙ
# =====================================================

Options -Indexes

# =====================================================
# 10. КЭШИРОВАНИЕ
# =====================================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/json "access plus 1 day"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# =====================================================
# 11. СЖАТИЕ
# =====================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml font/woff2
</IfModule>

# =====================================================
# 12. ЗАЩИТА ОТ DDOS (лимиты)
# =====================================================

<IfModule mod_limitipconn.c>
    MaxConnPerIP 20
</IfModule>

# =====================================================
# 13. ЗАЩИТА ОТ HOTLINKING (воровства картинок)
# =====================================================

<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^https?://wikivnezakona\.cc\.cd/ [NC]
    RewriteCond %{HTTP_REFERER} !^$
    RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,L]
</IfModule>
